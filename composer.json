{
    "name": "psc-acme/gateway-payment",
    "description": "Package gateway-payment for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\GatewayPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "nesbot/carbon": "^2.72",
        "league/commonmark": "^2.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}